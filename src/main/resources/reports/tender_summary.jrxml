	</parameter>
	<parameter name="department" class="java.lang.String"/>
	<parameter name="path" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
t.tender_id as tenderId,
t.tender_no as tenderNo,
t.tender_title as tenderTitle,
t.department as department,
t.estimated_value as estimatedValue,
t.publish_date as publishDate,
t.bid_end_date as bidEndDate,
t.tender_status as tenderStatus,
(select count(*) from bid_technical bt where bt.tender_id = t.tender_id
and bt.submission_status = 'SUBMITTED') as totalBids,
(select count(*) from bid_technical bt where bt.tender_id = t.tender_id
and bt.evaluation_status = 'QUALIFIED') as qualifiedBids
from publish_tender_header t
where (cast($P{start_date} as date) is null or t.publish_date >= cast($P{start_date} AS DATE))
and (cast($P{end_date}  as date) is null or t.publish_date <= cast($P{end_date} AS DATE))
and ($P{department} is null or t.department = $P{department})]]>
	</queryString>
